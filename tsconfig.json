{
	"include": ["src/**/*", "examples/**/*"],
	"compilerOptions": {
		"incremental": true,
		"outDir": "dist",
		"lib": ["es2025"],
		"module": "es2022",
		"sourceMap": true,
		"target": "es2025",
		"allowJs": true,
		"checkJs": true,
		"noEmit": true,
		"strict": true,
		"noImplicitAny": false,
		"noImplicitThis": false,
		"strictNullChecks": false,
		"paths": {
			"*": [
				"./node_modules/@moddable/typings/*",
				"./node_modules/@moddable/typings/ble/*",
				"./node_modules/@moddable/typings/web/*",
				"./src/m5chain/*",
				"./src/m5chain/m5chainDevices/*",
				"./src/m5chain/deviceFeatures/*"
			],
			"commodetto/*": ["./node_modules/@moddable/typings/commodetto/*"],
			"dns/*": ["./node_modules/@moddable/typings/dns/*"],
			"mc/*": ["./node_modules/@moddable/typings/mc/*"],
			"mod/*": ["./node_modules/@moddable/typings/mod/*"],
			"pins/*": ["./node_modules/@moddable/typings/pins/*"],
			"piu/*": ["./node_modules/@moddable/typings/piu/*"],
			"text/*": ["./node_modules/@moddable/typings/text/*"],
			"embedded:io/*": ["./node_modules/@moddable/typings/embedded_io/*"],
			"embedded:io/audio/*": ["./node_modules/@moddable/typings/embedded_io/audio/*"],
			"embedded:io/bluetooth/*": ["./node_modules/@moddable/typings/embedded_io/bluetooth/*"],
			"embedded:io/socket/*": ["./node_modules/@moddable/typings/embedded_io/socket/*"],
			"embedded:network/http/*": ["./node_modules/@moddable/typings/embedded_network/http/*"],
			"embedded:network/mqtt/*": ["./node_modules/@moddable/typings/embedded_network/mqtt/*"],
			"embedded:network/websocket/*": ["./node_modules/@moddable/typings/embedded_network/websocket/*"],
			"embedded:network/dns/resolver/*": ["./node_modules/@moddable/typings/embedded_network/dns/resolver/*"],
			"embedded:network/interface/*": ["./node_modules/@moddable/typings/embedded_network/interface/*"],
			"embedded:storage/*": ["./node_modules/@moddable/typings/embedded/storage/*"],
			"embedded:provider/*": ["./node_modules/@moddable/typings/embedded/provider/*"]
		},
		"types": [
			"./node_modules/@moddable/typings/xs",
			"./node_modules/@moddable/typings/mcpack",
			"./node_modules/@moddable/typings/global"
		]
	}
}
